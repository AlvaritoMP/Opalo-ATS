# Backend - copia este archivo a .env y completa los valores
# cp .env.example .env

PORT=5000
NODE_ENV=development

# URL del frontend local (Vite usa puerto 3000)
FRONTEND_URL=http://localhost:3000

# Supabase (SERVICE_KEY es distinta de ANON_KEY - obtener en Supabase > Settings > API)
SUPABASE_URL=https://afhiiplxqtodqxvmswor.supabase.co
SUPABASE_SERVICE_KEY=
# Opcional en desarrollo local si aún no tienes la service key:
SUPABASE_ANON_KEY=

# Google OAuth para Google Drive (copiar desde Easypanel o PC del trabajo)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
